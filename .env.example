# Product-specific database URLs.
#
# Neon example (recommended):
# - Create two databases in the same Neon project/branch (e.g. `audit_tools_yee`, `audit_tools_playsafe`)
# - Copy each connection string here, ensuring the database name matches the product DB
# - You can paste Neon’s standard `postgresql://...` URL directly (the app will normalize it for async SQLAlchemy)
#
# Local Postgres example:
# DATABASE_URL_YEE=postgresql+asyncpg://postgres:postgres@localhost:5432/audit_tools_yee
# DATABASE_URL_PLAYSAFE=postgresql+asyncpg://postgres:postgres@localhost:5432/audit_tools_playsafe

DATABASE_URL_YEE=
DATABASE_URL_PLAYSAFE=

# Legacy single-db configuration (optional)
# If you set DATABASE_URL (and leave DATABASE_URL_YEE empty), the app treats it as the YEE database.
# DATABASE_URL=
