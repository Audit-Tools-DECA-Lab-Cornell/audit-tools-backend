# Product-specific database URLs.
#
# Neon example (recommended):
# - Create two databases in the same Neon project/branch (e.g. `audit_tools_yee`, `audit_tools_playspace`)
# - Copy each connection string here, ensuring the database name matches the product DB
# - You can paste Neon’s standard `postgresql://...` URL directly (the app will normalize it for async SQLAlchemy)
#
# Local Postgres example:
# DATABASE_URL_YEE=postgresql+asyncpg://postgres:postgres@localhost:5432/audit_tools_yee
# DATABASE_URL_PLAYSPACE=postgresql+asyncpg://postgres:postgres@localhost:5432/audit_tools_playspace

DATABASE_URL_YEE=
DATABASE_URL_PLAYSPACE=

# Legacy single-db configuration (optional)
# If you set DATABASE_URL (and leave DATABASE_URL_YEE empty), the app treats it as the YEE database.
# DATABASE_URL=

# Auth / session configuration
# Used for signed bearer tokens returned by /yee/auth/login and /playspace/auth/login
AUTH_TOKEN_SECRET_KEY=
AUTH_ACCESS_TOKEN_TTL_DAYS=7

# Optional email verification + anti-bot configuration
AUTH_EMAIL_VERIFY_TTL_HOURS=24
TURNSTILE_SECRET_KEY=
AUTH_VERIFY_URL_TEMPLATE=

# Optional SMTP configuration for sending verification emails.
# If these are not set, verification links are logged to the backend console in local development.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
